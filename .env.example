# LLM API Keys
# 复制此文件为 .env 并填入你的实际密钥
# Copy this file to .env and fill in your actual keys

# ═══════════════════════════════════════════════════════════════
# Main LLM Provider Keys (至少需要配置一个)
# ═══════════════════════════════════════════════════════════════

# MiniMax (推荐 - 国产高性能)
# 获取地址: https://platform.minimaxi.com/apiKeys
MINIMAX_API_KEY=
# MiniMax Base URL (可选，默认使用 MiniMax-M2 系列地址)
MINIMAX_BASE_URL=

# OpenAI (可选 - 需要代理)
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# OpenAI Base URL (可选)
OPENAI_BASE_URL=

# Anthropic Claude (可选 - 需要代理)
# 获取地址: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# DeepSeek (可选)
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
# DeepSeek Base URL (可选)
DEEPSEEK_BASE_URL=

# Moonshot / Kimi (可选)
# 获取地址: https://platform.moonshot.cn/console/api-keys
MOONSHOT_API_KEY=

# ═══════════════════════════════════════════════════════════════
# Other Optional Providers
# ═══════════════════════════════════════════════════════════════

# Google Gemini
GOOGLE_API_KEY=

# SiliconFlow (国产聚合)
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=

# 智谱 AI (GLM)
GLM_API_KEY=
ZHIPU_BASE_URL=

# 通义千问 (DashScope)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=

# Groq
GROQ_API_KEY=
GROQ_BASE_URL=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=

# ═══════════════════════════════════════════════════════════════
# Application Settings
# ═══════════════════════════════════════════════════════════════

# Gateway API Key (可选 - 用于 API Gateway)
GATEWAY_API_KEY=

# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# 默认 LLM Provider (minimax/openai/anthropic/deepseek/moonshot等)
DEFAULT_PROVIDER=minimax